<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">

<title>كتاب الحمام الزاجل</title>

<style>

body{
margin:0;
background:#111;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
overflow:hidden;
}

img{
width:100%;
height:100%;
object-fit:contain;
cursor:pointer;
}

</style>

</head>

<body>

<img id="page" src="../page1.jpg">

<script>

let page=1;

document.getElementById("page").onclick=function(){

page++;

if(page>8){
page=1;
}

this.src="../page"+page+".jpg";

};

</script>

</body>
</html>